---
import type { LayoutProps } from './type'
import { getEntry } from 'astro:content'

type Props = LayoutProps

const {
  data: { title: siteTitle, description: siteDescription }
} = await getEntry('site', 'site')
const { title, description, hidden } = Astro.props
---

{/* Basic SEO tags */}
<title>{title ? `${title} \u2014 ${siteTitle}` : siteTitle}</title>
<meta name='description' content={description || siteDescription} />
<meta name='robots' content={hidden ? 'noindex, nofollow' : 'index, follow'} />
<link rel='canonical' href={Astro.url.href} />
