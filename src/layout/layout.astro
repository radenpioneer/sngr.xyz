---
import type { LayoutProps } from './type'
import BaseLayout from './base.astro'
import SEO from './seo.astro'

type Props = LayoutProps
const { title, description, hidden } = Astro.props
---

<BaseLayout>
  {/* <head /> */}
  <Fragment slot='head'>
    <SEO title={title} description={description} hidden={hidden} />
    <link
      rel='preload'
      href='/fonts/Affigere-Regular.woff2'
      as='font'
      type='font/woff2'
      crossorigin='anonymous'
    />
    <slot name='head' />
  </Fragment>

  {/* <body /> */}
  <Fragment>
    <slot />
  </Fragment>
</BaseLayout>

<style is:global>
  @font-face {
    font-family: 'Affigere';
    src:
      url('/fonts/Affigere-Regular.woff2') format('woff2'),
      url('/fonts/Affigere-Regular.woff') format('woff'),
      url('/fonts/Affigere-Regular.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
    unicode-range: U+000-5FF; /* Basic Latin and Latin-1 Supplement */
  }
</style>
