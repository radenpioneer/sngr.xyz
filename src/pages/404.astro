---
import Layout from '../layouts/layout.astro'

const title = '404 Not Found'
---

<Layout title={title}>
  <main>
    <section
      class='min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-green-50 to-blue-200 px-4'
    >
      <h1
        class='font-heading font-extrabold text-6xl bg-gradient-to-br from-green-500 to-purple-500 bg-clip-text text-transparent box-shadow-md'
      >
        <span>{title}</span>
      </h1>
    </section>
  </main>
</Layout>
