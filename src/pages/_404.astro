---
import Layout from '~/layouts/layout.astro'

const title = '404 Not Found'
---

<Layout title={title}>
  <main>
    <section
      class='flex min-h-screen flex-col items-center justify-center bg-gradient-to-br from-green-50 to-blue-200 px-4'
    >
      <h1
        class='box-shadow-md font-heading bg-gradient-to-br from-green-500 to-purple-500 bg-clip-text text-6xl font-extrabold text-transparent'
      >
        <span>{title}</span>
      </h1>
    </section>
  </main>
</Layout>
