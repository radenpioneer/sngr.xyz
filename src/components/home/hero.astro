---
import {
  HeroSection as HeroSectionComponent,
  type HeroSectionProps
} from './hero'

interface Props extends HeroSectionProps {}

const { site, logo } = Astro.props
const { Content } = await site.render()
---

<HeroSectionComponent site={site} logo={logo} client:load>
  <Content />
</HeroSectionComponent>
