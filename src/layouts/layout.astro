---
import BaseLayout, { type Props as BaseLayoutProps } from './base.astro'
import SEO, { type Props as SEOProps } from '~/components/site/seo.astro'
import Header from '~/components/header/header.astro'
import Icons from '~/components/site/icons.astro'
import '@fontsource-variable/radio-canada'
import '@fontsource-variable/radio-canada-big'
import './main.css'

export interface Props extends SEOProps, Omit<BaseLayoutProps, 'title'> {}

const { title, description, class: className, ...props } = Astro.props
---

<BaseLayout
  class:list={['font-display text-text bg-bg/[.75]', className]}
  {...props}
>
  {/* <head /> */}
  <Fragment slot='head'>
    <SEO title={title} description={description} />
    <Icons />
    <slot name='head' />
  </Fragment>

  {/* <body /> */}
  <Header />
  <slot />
</BaseLayout>
