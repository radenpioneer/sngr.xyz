---
import BaseLayout, { type Props as BaseLayoutProps } from './base.astro'
import SEO, { type Props as SEOProps } from './seo.astro'
import GradientBackground from '~/components/site/background.astro'

interface Props extends SEOProps, Omit<BaseLayoutProps, 'title'> {}

const { title, description, class: className, ...attrs } = Astro.props
---

<BaseLayout class:list={['font-mono', className]} {...attrs}>
  {/* <head> */}
  <Fragment slot='head'>
    <SEO title={title} description={description} />
    <slot name='head' />
  </Fragment>

  {/* <body> */}
  <slot />
  <GradientBackground />
</BaseLayout>
