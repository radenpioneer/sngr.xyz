---
import BaseLayout from './base.astro'
import SEO, { type Props as SEOProps } from './seo.astro'

interface Props extends SEOProps {}

const { title, description } = Astro.props
---

<BaseLayout>
  {/* <head> */}
  <Fragment slot='head'>
    <SEO title={title} description={description} />
    <slot name='head' />
  </Fragment>

  {/* <body> */}
  <slot />
</BaseLayout>
